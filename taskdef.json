{
  "family": "jenkins-task",
  "containerDefinitions": [
    {
      "name": "jenkins-demo",
      "image": "159773342061.dkr.ecr.ap-northeast-2.amazonaws.com/jenkins-demo:latest",
      "essential": true,
      "portMappings": [
        {
          "containerPort": 8080,
          "hostPort": 8080
        }
      ]
    }
  ],
  "requiresCompatibilities": ["FARGATE"],
  "networkMode": "awsvpc",
  "cpu": "256",
  "memory": "512",
  "executionRoleArn": "arn:aws:iam::159773342061:role/ecsTaskExecutionRole"
}
